{
  "compilerOptions": {
    "target": "ES2020",
    "skipLibCheck": true,
    "module": "CommonJS",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "paths": {
      "shared-2048-logic/*": [
        "../../packages/shared-2048-logic/src/*"
      ]
    },
    "typeRoots": [
      "./node_modules/@types",
      "./src/types"
    ],
    "types": [
      "node",
      "express"
    ]
  },
  "include": [
    "src",
    "types"
  ]
}